%div{style: "display:flex; justify-content:center;"}
  %div
    %h1{style:"color: navy;"} Appointments
    - if notice
      %p{color: "red"}=notice

    = link_to "New appointment", new_appointment_path

    %table{border: "1"}
      %thead
        %tr
          %th Reason
          %th Appoitment Date
          %th Doctor
          %th Patient
          %th{colspan:"3"} Actions
      %tbody
        - @appointments.each do |appointment|
          %tr
            %td= appointment.reason
            %td= appointment.appointment_date
            %td= appointment.doctor.name
            %td= appointment.patient.name
            %td= link_to "Show", appointment_path(appointment)
            %td= link_to "Edit", edit_appointment_path(appointment)
            %td= link_to "Delete", appointment_path(appointment), data: {turbo_method: :delete,turbo_confirm: "Are you sure?"}
