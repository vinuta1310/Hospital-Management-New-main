#notification

= link_to "New patient", new_patient_path, data: { turbo_frame: "modal" }
= turbo_frame_tag "modal"
  

%h1 Patients

%table{border: "1"}
  %thead
    %tr
      %th ID
      %th Name
      %th Age
      %th Gender
      %th Born On
      %th{colspan: "3"} Actions
  %tbody#patient_body
    = render @patients
